# Data lives with each pipeline under pipelines/<name>/data/ (see each pipeline's
# own .gitignore). There is no top-level data/ tree; the curated source catalog is
# tracked at docs/planning/colorado_environmental_data_sources.json.

# Large / binary artifacts (use object storage or Git LFS instead)
*.parquet
*.feather
*.h5
*.hdf5
*.pkl
*.joblib
*.sqlite
*.db

# Secrets and credentials — never commit
.env
.env.*
!.env.example
*.key
*.pem
credentials.json
secrets.yaml

# Notebook cruft — clear outputs before committing
.ipynb_checkpoints/
*-checkpoint.ipynb

# Python
__pycache__/
*.py[cod]
.venv/
env/
.conda/
.pytest_cache/
.ruff_cache/
.mypy_cache/

# OS / editor
.DS_Store
Thumbs.db
.vscode/
.idea/
*.swp
