# Generated pipeline outputs — reproducible from the sources; keep dirs via .gitkeep.
data/original/*
data/processed/*
data/audit/*
!data/**/.gitkeep

# Hand-curated lookups ARE committed (data/lookups/ is not ignored).

# Dataverse deposit record (per-environment pid/URL of the draft; not committed).
dataverse/.dataverse-deposit.json

# Secrets — API keys never committed (reservoir uses $CDSS_API_KEY; the key-file
# fallback is defensive so a stray key dropped here can't be staged by accident).
dwr_api.json
*.api.json

# Auto-generated column profile (regenerated by audit.variables_report)
docs/variables.csv

# Caches / build
.requests-cache.sqlite*
__pycache__/
*.py[cod]
.ipynb_checkpoints/
*-checkpoint.ipynb
.pytest_cache/
.ruff_cache/
.venv/
